@baseUrl = http://localhost:8080

# Datos iniciales cargados desde src/main/resources/data.sql
@ambienteDisponibleId = 1002
@ambienteOcupadoId = 1001
@ambienteInactivoId = 1004
@ambienteInstructorId = 1005
@reservaCancelableId = 2007
@reservaCancelacionTardiaId = 2008

@ambienteInexistenteId = 999999
@reservaInexistenteId = 999999

@fechaConsulta = 2027-07-01
@fechaReporteInicio = 2027-07-01
@fechaReporteFin = 2027-07-07
@fechaSemana = 2027-07-01

### OK - POST /api/ambientes - Registrar ambiente
POST {{baseUrl}}/api/ambientes
Content-Type: application/json

{
  "nombre": "Laboratorio Pruebas HTTP",
  "tipo": "LABORATORIO",
  "capacidad": 30,
  "activo": true
}

### FALLA - POST /api/ambientes - Validacion declarativa: nombre vacio y capacidad invalida
POST {{baseUrl}}/api/ambientes
Content-Type: application/json

{
  "nombre": "",
  "tipo": "LABORATORIO",
  "capacidad": 0,
  "activo": true
}

### FALLA - POST /api/ambientes - Tipo de ambiente invalido
POST {{baseUrl}}/api/ambientes
Content-Type: application/json

{
  "nombre": "Ambiente con tipo invalido",
  "tipo": "CANCHA",
  "capacidad": 25,
  "activo": true
}

### OK - GET /api/ambientes - Listar todos los ambientes
GET {{baseUrl}}/api/ambientes

### FALLA - GET /api/ambientes - Ruta incorrecta
GET {{baseUrl}}/api/ambientes-no-existe

### OK - POST /api/reservas - Crear reserva activa
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambienteId": {{ambienteDisponibleId}},
  "nombreInstructor": "Ana Gomez",
  "fechaInicio": "2027-07-06T08:00:00",
  "fechaFin": "2027-07-06T10:00:00",
  "numeroAprendices": 20
}

### FALLA - POST /api/reservas - Regla: ambiente inexistente
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambienteId": {{ambienteInexistenteId}},
  "nombreInstructor": "Ana Gomez",
  "fechaInicio": "2027-07-06T11:00:00",
  "fechaFin": "2027-07-06T13:00:00",
  "numeroAprendices": 20
}

