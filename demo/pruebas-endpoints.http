@baseUrl = http://localhost:8080

# Cambia estas fechas si ya quedaron en el pasado.
@fechaInicio = 2026-07-01T08:00:00
@fechaFin = 2026-07-01T10:00:00
@fechaInicioLibre = 2026-07-01T14:00:00
@fechaFinLibre = 2026-07-01T16:00:00
@fechaConsulta = 2026-07-01
@fechaReporteInicio = 2026-07-01
@fechaReporteFin = 2026-07-01

# Despues de ejecutar "OK - POST /api/ambientes", copia el id devuelto aqui.
@ambienteId = 1

# Despues de ejecutar "OK - POST /api/reservas", copia el id devuelto aqui.
@reservaId = 1

@ambienteInexistenteId = 999999
@reservaInexistenteId = 999999

### OK - POST /api/ambientes - Registrar ambiente laboratorio
# @name crearAmbiente
POST {{baseUrl}}/api/ambientes
Content-Type: application/json

{
  "nombre": "Laboratorio Pruebas HTTP",
  "tipo": "LABORATORIO",
  "capacidad": 30,
  "activo": true
}

### FALLA - POST /api/ambientes - Tipo de ambiente invalido
POST {{baseUrl}}/api/ambientes
Content-Type: application/json

{
  "nombre": "Ambiente con tipo invalido",
  "tipo": "CANCHA",
  "capacidad": 25,
  "activo": true
}

### OK - GET /api/ambientes - Listar todos los ambientes
GET {{baseUrl}}/api/ambientes

### FALLA - GET /api/ambientes - Ruta incorrecta
GET {{baseUrl}}/api/ambientes-no-existe

### OK - POST /api/reservas - Crear reserva activa
# @name crearReserva
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambiente": {
    "id": {{ambienteId}},
    "activo": true
  },
  "nombreInstructor": "Ana Gomez",
  "fechaInicio": "{{fechaInicio}}",
  "fechaFin": "{{fechaFin}}",
  "numeroAprendices": 25
}

### FALLA - POST /api/reservas - Ambiente inexistente
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambiente": {
    "id": {{ambienteInexistenteId}},
    "activo": true
  },
  "nombreInstructor": "Ana Gomez",
  "fechaInicio": "{{fechaInicioLibre}}",
  "fechaFin": "{{fechaFinLibre}}",
  "numeroAprendices": 25
}

### FALLA - POST /api/reservas - Reserva solapada con otra activa
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambiente": {
    "id": {{ambienteId}},
    "activo": true
  },
  "nombreInstructor": "Carlos Ruiz",
  "fechaInicio": "2026-07-01T09:00:00",
  "fechaFin": "2026-07-01T11:00:00",
  "numeroAprendices": 20
}

### FALLA - POST /api/reservas - Supera capacidad del ambiente
POST {{baseUrl}}/api/reservas
Content-Type: application/json

{
  "ambiente": {
    "id": {{ambienteId}},
    "activo": true
  },
  "nombreInstructor": "Laura Perez",
  "fechaInicio": "{{fechaInicioLibre}}",
  "fechaFin": "{{fechaFinLibre}}",
  "numeroAprendices": 999
}

### OK - GET /api/ambientes/{id}/reservas - Reservas activas de un ambiente por fecha
GET {{baseUrl}}/api/ambientes/{{ambienteId}}/reservas?fecha={{fechaConsulta}}

### FALLA - GET /api/ambientes/{id}/reservas - Fecha con formato invalido
GET {{baseUrl}}/api/ambientes/{{ambienteId}}/reservas?fecha=01-07-2026

### OK - GET /api/ambientes/disponibles - Consultar ambientes disponibles en rango libre
GET {{baseUrl}}/api/ambientes/disponibles?fechaInicio={{fechaInicioLibre}}&fechaFin={{fechaFinLibre}}

### OK - GET /api/ambientes/disponibles - Consultar disponibles con filtros
GET {{baseUrl}}/api/ambientes/disponibles?fechaInicio={{fechaInicioLibre}}&fechaFin={{fechaFinLibre}}&capacidadMinima=20&tipo=LABORATORIO

### FALLA - GET /api/ambientes/disponibles - Fecha fin anterior a fecha inicio
GET {{baseUrl}}/api/ambientes/disponibles?fechaInicio=2026-07-01T10:00:00&fechaFin=2026-07-01T08:00:00

### FALLA - GET /api/ambientes/disponibles - Tipo de ambiente invalido
GET {{baseUrl}}/api/ambientes/disponibles?fechaInicio={{fechaInicioLibre}}&fechaFin={{fechaFinLibre}}&tipo=CANCHA

### OK - GET /api/reportes/ocupacion - Reporte de ocupacion por rango de fechas
GET {{baseUrl}}/api/reportes/ocupacion?fechaInicio={{fechaReporteInicio}}&fechaFin={{fechaReporteFin}}

### FALLA - GET /api/reportes/ocupacion - Fecha fin anterior a fecha inicio
GET {{baseUrl}}/api/reportes/ocupacion?fechaInicio=2026-07-02&fechaFin=2026-07-01

### FALLA - GET /api/reportes/ocupacion - Formato de fecha invalido
GET {{baseUrl}}/api/reportes/ocupacion?fechaInicio=01-07-2026&fechaFin=2026-07-01

### OK - PATCH /api/reservas/{id}/cancelar - Cancelar reserva
PATCH {{baseUrl}}/api/reservas/{{reservaId}}/cancelar

### FALLA - PATCH /api/reservas/{id}/cancelar - Reserva inexistente
PATCH {{baseUrl}}/api/reservas/{{reservaInexistenteId}}/cancelar

### FALLA - PATCH /api/reservas/{id}/cancelar - Id con formato invalido
PATCH {{baseUrl}}/api/reservas/abc/cancelar
